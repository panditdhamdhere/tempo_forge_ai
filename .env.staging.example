# TempoForge staging — copy to .env.staging and fill every value.
# cp .env.staging.example .env.staging

APP_ENV=staging
ALLOW_DEV_AUTH=false

# Public URLs (HTTPS in real staging)
APP_URL=https://staging.tempoforge.ai
API_PUBLIC_URL=https://api.staging.tempoforge.ai
NEXT_PUBLIC_API_URL=https://api.staging.tempoforge.ai
CORS_ORIGINS=https://staging.tempoforge.ai

API_HOST=0.0.0.0
API_PORT=8080
API_PUBLISH_PORT=8080
WEB_PUBLISH_PORT=3000

# Strong unique secrets — generate with:
#   openssl rand -hex 32
POSTGRES_USER=tempoforge
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tempoforge
DATABASE_URL=postgres://tempoforge:change_me_strong_password@postgres:5432/tempoforge
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333

ENCRYPTION_KEY=replace_with_openssl_rand_hex_32

# Clerk (required in staging)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
JWT_AUDIENCE=tempoforge-api
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# AI
AI_PROVIDER=groq
GROQ_API_KEY=gsk_...
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Stripe (use test mode for staging)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_...
NEXT_PUBLIC_STRIPE_PRICE_TEAM=price_...

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=tempoforge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_minio_secret
S3_FORCE_PATH_STYLE=true

# Tempo
TEMPO_DEFAULT_NETWORK=testnet
TEMPO_TESTNET_RPC=https://rpc.moderato.tempo.xyz
TEMPO_MAINNET_RPC=https://rpc.tempo.xyz
TEMPO_TESTNET_CHAIN_ID=42431

API_RATE_LIMIT_PER_MINUTE=120
RUST_LOG=info,tempoforge=info
