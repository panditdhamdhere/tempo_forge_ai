# TempoForge AI — environment template
# Copy to .env and fill in values: cp .env.example .env

# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info,tempoforge=debug

# PostgreSQL
DATABASE_URL=postgres://tempoforge:tempoforge@localhost:5432/tempoforge

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# Indexer worker
INDEXER_POLL_MS=2000
INDEXER_START_BLOCK=

# S3-compatible storage (MinIO locally)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tempoforge
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-instance.clerk.accounts.dev
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_PRICE_PRO=price_replace_me
STRIPE_PRICE_TEAM=price_replace_me
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_replace_me
NEXT_PUBLIC_STRIPE_PRICE_TEAM=price_replace_me

# AI — Groq (OpenAI-compatible) for testing; swap via AI_PROVIDER
AI_PROVIDER=groq
GROQ_API_KEY=gsk_replace_me
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2

# Tempo Blockchain
TEMPO_MAINNET_RPC=https://rpc.tempo.xyz
TEMPO_TESTNET_RPC=https://rpc.moderato.tempo.xyz
TEMPO_MAINNET_CHAIN_ID=4242
TEMPO_TESTNET_CHAIN_ID=42431
TEMPO_DEFAULT_NETWORK=testnet

# Security
API_RATE_LIMIT_PER_MINUTE=120
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
JWT_AUDIENCE=tempoforge-api

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=tempoforge-api
